# Copy to .env (for `netlify dev`) and fill in real values.
# .env is gitignored — never commit it.

# Supabase (frontend, prefixed with VITE_ to be exposed to client)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service role key — needed ONLY by the daily-curator scheduled
# function to bypass RLS and insert global daily works. ⚠️ Highly sensitive:
# full DB access. Never put this in a `VITE_`-prefixed var, never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# DeepSeek (Netlify Function only, NOT exposed to the browser)
DEEPSEEK_API_KEY=

# Email allowed to edit hotspots on global (system-published) daily works.
# Set BOTH of these to the same value — the VITE_ one shows the "调看点"
# button in the UI, the non-prefixed one is the server-side check that
# actually enforces permission. Not sensitive (just an email).
VITE_ADMIN_EMAIL=
ADMIN_EMAIL=
