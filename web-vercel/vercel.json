{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/u/:handle", "destination": "/api/u?handle=:handle" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/daily-curator", "schedule": "0 16 * * *" },
    { "path": "/api/extend-seed", "schedule": "0 18 * * 1" }
  ]
}
